############################
# Next.js Credentials
############################
NEXT_PUBLIC_BASE_URL=http://localhost:8080
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

############################
# PostgreSQL Credentials
############################
POSTGRES_DB=stocks_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

############################
# Spring Boot Secrets
############################
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=

# Database
DB_NAME=stocks_db
DB_USERNAME=postgres
DB_PASSWORD=
DB_HOST=database
DB_PORT=5432

# VAPID
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# App URLs
APP_BASE_URL=http://localhost:8080
APP_ALLOWED_ORIGINS=http://localhost:3000

# S3
S3_BUCKET_NAME=spring-boot-nextjs-starter
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BASE_URL=http://s3.tebi.io
S3_REGION=europe-central-1
S3_STORAGE_CLASS=STANDARD

# Admin user
ADMIN_USER_EMAIL=
ADMIN_USER_PASSWORD=

# OAuth2 - GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth2 - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Mail
SPRING_MAIL_HOST=mailpit
SPRING_MAIL_PORT=1025
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=

# External services
YFINANCE_API_URL=http://yfinance-fastapi:8000
